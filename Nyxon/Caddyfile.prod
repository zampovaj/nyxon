nyxon.app {

    tls johanazampova@gmail.com

    # Enable access logs to see exactly what Caddy is routing
    log {
        output stdout
    }

    # Reverse proxy API and SignalR hub to backend container
    reverse_proxy /api/* server:8080
    reverse_proxy /hubs/* server:8080

    # Serve static frontend (Blazor WASM) from Caddy root
    reverse_proxy /* server:8080 {
        # Optional headers for SPA, only needed if you do special routing
        header_up Host {host}
    }

    # Security headers
    header {
        X-Frame-Options "DENY"
        X-XSS-Protection "1; mode=block"
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        // for blazor, using 'unsafe-inline' is a common practice
        // wasm is a giant pile of binary, most logic is handled internally --> tha tmakes it less vulnerable
        // for maximum security, 'unsafe-inline' could be replaced with hash value
        // since the hash might change unpredictably and break the app, this will not be implemented
        Content-Security-Policy "default-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; script-src 'self' 'wasm-unsafe-eval' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com https://fonts.googleapis.com; font-src 'self' https://cdnjs.cloudflare.com https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self' ws: wss:; object-src 'none';"
    }
}
