@inherits LayoutComponentBase
@using MudBlazor
@using Microsoft.AspNetCore.Components.Authorization
@using Nyxon.Client.Services
@using Nyxon.Client.Interfaces
@using System.Text

@inject NavigationManager Nav
@inject LayoutService LayoutState
@inject IAuthenticationService AuthService
@inject AuthenticationStateProvider AuthStateProvider
@inject ClientOrchestratorService Orchestrator

<MudThemeProvider Theme="NyxonTheme.Default" IsDarkMode="true" />
<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />  <div class="layout-shell">
    <header class="app-header">
        <div class="header-content">

            <div style="display: flex; align-items: center;">
                <a href="/" @onclick="Home" class="logo-link">nyxon</a>

                @if (!string.IsNullOrEmpty(LayoutState.HeaderTitle))
                {
                    <AuthorizeView>
                        <div class="breadcrumb visible" style="display: flex; align-items: center;">
                            <span class="breadcrumb-divider">/</span>
                            <span class="context-title">@LayoutState.HeaderTitle</span>
                            <span class="encrypted-badge">ENCRYPTED</span>
                        </div>
                    </AuthorizeView>
                }
            </div>

            <nav class="nav-links">
                <AuthorizeView>
                    <Authorized>
                        <div class="nav-links-log">
                            <div class="user-link" @onclick='() => Nav.NavigateTo("/settings")'>
                                <MudAvatar class="avatar user-avatar">
                                    @(context.User.Identity?.Name?.Substring(0, 1).ToUpper() ?? "?")
                                </MudAvatar>
                                <a class="username">@context.User.Identity?.Name</a>
                            </div>
                            <a class="logout-link" href="#" @onclick="Logout">➜] Logout</a>
                        </div>
                    </Authorized>
                    <NotAuthorized>
                        <a href="https://github.com/zampovaj/nyxon" class="nav-item">GitHub</a>
                        @if (!Nav.Uri.Contains("login"))
                        {
                            <button style="margin-left: 20px" class="btn-primary" @onclick='() => Nav.NavigateTo("/login")'>
                                Login / Register
                            </button>
                        }
                    </NotAuthorized>
                </AuthorizeView>
            </nav>
        </div>
    </header>

    <AuthorizeView>
        <Authorized>
            <div class="app-layout">
                <AppSidebar />
                <main class="main-stage">
                    @Body
                </main>
            </div>
        </Authorized>
        <NotAuthorized>
            <main style="flex: 1; display: flex; flex-direction: column; overflow: hidden; width: 100%;">
                @Body
            </main>
        </NotAuthorized>
    </AuthorizeView>
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        LayoutState.OnChange += StateHasChanged;
        Nav.LocationChanged += OnLocationChanged;
        await Orchestrator.Initialize();
    }

    public void Dispose()
    {
        LayoutState.OnChange -= StateHasChanged;
        Nav.LocationChanged -= OnLocationChanged;
        Orchestrator.Dispose();
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        StateHasChanged();
    }

    private void Home()
    {
        LayoutState.SetHeaderTitle("");
    }

    private async Task Logout()
    {
        await AuthService.LogoutAsync();

        LayoutState.SetHeaderTitle("");
        Nav.NavigateTo("/");
    }
}
