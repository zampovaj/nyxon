@inherits LayoutComponentBase
@using MudBlazor
@inject NavigationManager Nav
@using Nyxon.Client.Services
@inject LayoutService LayoutState
@implements IDisposable // need this to prevetn memory leaks

<MudThemeProvider Theme="NyxonTheme.Default" IsDarkMode="true" />
<MudDialogProvider />
<MudSnackbarProvider />

<div class="layout-shell">
    
    <header class="app-header">
        <div class="header-content">
            
            <div style="display: flex; align-items: center;">
                <a href="/" class="logo-link">nyxon</a>
                
                @if (!string.IsNullOrEmpty(LayoutState.HeaderTitle))
                {
                    <div class="breadcrumb visible" style="display:flex; margin-left:20px;">
                        <span class="breadcrumb-divider">/</span>
                        <span class="context-title">@LayoutState.HeaderTitle</span>
                        <span class="encrypted-badge">ENCRYPTED</span>
                    </div>
                }
            </div>

            <nav class="nav-links">
                @if (LayoutState.IsLoggedIn)
                {
                    <div style="display: flex; align-items: center; gap: 10px; border-right: 1px solid var(--border); padding-right: 20px; margin-right: 20px;">
                        <MudAvatar Color="Color.Primary" Size="Size.Small" Style="color: black; font-weight: bold;">F</MudAvatar>
                        <span style="font-size: 0.9rem; font-weight: 500;">FinalBoss</span>
                    </div>
                    
                    <a href="#" @onclick="Logout" style="color: var(--error);">Logout</a>
                }
                else
                {
                    <a href="manifesto" class="nav-item">Manifesto</a>
                    <a href="security" class="nav-item">Security</a>
                    <a href="login" class="nav-item">Login</a>
                }
            </nav>
        </div>
    </header>

    @if (LayoutState.IsLoggedIn)
    {
        <div class="app-layout">
            <AppSidebar /> <main class="main-stage">
                @Body
            </main>
        </div>
    }
    else
    {
        <main style="flex: 1; display: flex; flex-direction: column; overflow: hidden; width: 100%;">
            @Body
        </main>
    }
</div>

@code {
    protected override void OnInitialized()
    {
        // Listen for updates (Login, Logout, Chat Click)
        LayoutState.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        LayoutState.OnChange -= StateHasChanged;
    }

    private void Logout()
    {
        LayoutState.SetLoggedInState(false);
        Nav.NavigateTo("/");
    }
}