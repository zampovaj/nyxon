@using Nyxon.Client.Services
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject LayoutService LayoutState

<aside class="sidebar">
    <div class="sidebar-top">
        <div class="collapsed-icon">#</div>
        <div class="expanded-search">
            <input type="text" class="input-std" placeholder="Filter chats...">
        </div>
    </div>
    <div class="side-nav-list">
        <div class="side-nav-item" @onclick='() => TryOpenChat("Alice")'>
            <MudAvatar class="avatar side-avatar">
                A
            </MudAvatar>
            <div class="side-nav-info">
                <span class="chat-name">Alice</span>
                <span class="chat-preview">Project Nyxon is live.</span>
            </div>
        </div>
        
        <div class="side-nav-item" @onclick='() => TryOpenChat("Bob")'>
            <MudAvatar class="avatar side-avatar">
                B
            </MudAvatar>
            <div class="side-nav-info">
                <span class="chat-name">Bob (Dev)</span>
                <span class="chat-preview">Key rotation successful.</span>
            </div>
        </div>
    </div>
    <div class="sidebar-bottom">
        <div class="status-dot-wrapper">
            <div class="status-dot"></div>
        </div>
        <div class="status-text">
            Online (24ms) // v1.0.4
        </div>
    </div>
</aside>

@code {
    protected override void OnInitialized()
    {
        LayoutState.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        LayoutState.OnChange -= StateHasChanged;
    }

    private void TryOpenChat(string name)
    {
        // TODO: Re-implement Vault check later when we have EncryptionService
        // if (!LayoutState.IsVaultUnlocked) ...

        LayoutState.SetHeaderTitle(name);
        Nav.NavigateTo($"/chat");
    }
}