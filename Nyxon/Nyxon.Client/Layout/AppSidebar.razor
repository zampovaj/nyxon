@using Nyxon.Client.Services
@inject LayoutService LayoutState
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<aside class="sidebar">
    <div class="sidebar-top">
        <div class="collapsed-icon">#</div>
        <div class="expanded-search">
            <input type="text" class="input-std" placeholder="Filter chats...">
        </div>
    </div>
    <div class="side-nav-list">
        <div class="side-nav-item" @onclick="() => OpenAlice()">
            <MudAvatar class="avatar side-avatar">
                A
            </MudAvatar>
            <div class="side-nav-info">
                <span class="chat-name">Alice</span>
                <span class="chat-preview">Project Nyxon is live.</span>
            </div>
        </div>
        <div class="side-nav-item" onclick="openChat('Bob')">
            <MudAvatar class="avatar side-avatar">
                B
            </MudAvatar>
            <div class="side-nav-info">
                <span class="chat-name">Bob (Dev)</span>
                <span class="chat-preview">Key rotation successful.</span>
            </div>
        </div>
    </div>
    <div class="sidebar-bottom">
        <div class="status-dot-wrapper">
            <div class="status-dot"></div>
        </div>
        <div class="status-text">
            Online (24ms) // v1.0.4
        </div>
    </div>
</aside>

@code {
    protected override void OnInitialized()
    {
        // Listen for changes so the "••••••" turns into text immediately when unlocked
        LayoutState.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        LayoutState.OnChange -= StateHasChanged;
    }

    private void OpenAlice()
    {
        Nav.NavigateTo("/chat");
        LayoutState.SetHeaderTitle("Alice");
    }

    private void TryOpenChat(string name)
    {
        if (!LayoutState.IsVaultUnlocked)
        {
            Snackbar.Add("Enter passphrase to decrypt conversations.", Severity.Warning);
            return;
        }

        LayoutState.SetHeaderTitle(name);
        Nav.NavigateTo($"/chat/{name}");
    }
}