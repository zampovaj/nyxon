@page "/chat/{Username}"

@inject NavigationManager Nav
@inject IConversationService ConversationService
@inject IInboxService InboxService

@code
{
    [Parameter]
    public string Username { get; set; }

    protected override async Task OnInitializedAsync()
    {
        int stage = 0;
        Console.WriteLine("Redirect opened");
        try
        {
            if (string.IsNullOrEmpty(Username) || string.IsNullOrWhiteSpace(Username))
            {
                Console.WriteLine("Username empty");
                Nav.NavigateTo("/", false);
                return;
            }
            stage++;

            var conversationId = await InboxService.GetConversationAsync(Username);
            stage++;

            if (conversationId != null)
            {
                Nav.NavigateTo($"/chat/{conversationId}", false);
                return;
            }
            stage++;

            conversationId = await ConversationService.CreateConversationAsync(Username);
            stage++;

            if (conversationId == null)
            {
                Nav.NavigateTo("/", false);
                return;
            }
            stage++;

            Nav.NavigateTo($"/chat/{conversationId}", false);
            return;
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
        finally {
            Console.WriteLine($"Stage: {stage}");
        }
    }
}