@page "/"
@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Nav
@inject HomeViewModel _vm

<AuthorizeView>
    <Authorized>
        <div class="dashboard-view" @onkeydown:window="HandleGlobalKey">
            <h1 class="dash-greeting">Good afternoon, @context.User.Identity?.Name.</h1>

            <div class="dash-search-wrapper">
                <span class="dash-icon">></span>
                <input @ref="_terminalInput" type="text" class="dash-search"
                    placeholder="@(_vm.IsUnlocked ? "Type a command or user..." : "Enter passphrase to unlock")"
                    @bind="_vm.InputMessage" @onkeydown="_vm.HandleTerminalKey">
            </div>

            <div class="dash-shortcuts">
                @if (_vm.IsUnlocked)
                {
                    <div class="shortcut-chip">type ? for help</div>
                    <div class="shortcut-chip">:command</div>
                    <div class="shortcut-chip">@@username</div>
                }
                else
                {
                    <div class="shortcut-chip">:unlock <b>passphrase</b></div>
                }
            </div>

        </div>
    </Authorized>
    <NotAuthorized>
        <section class="landing-hero">
            <h1 class="hero-title">Sovereignty over<br>your data.</h1>
            <p class="hero-subtitle">End-to-End Encrypted.
                Zero Knowledge.<br>The last messenger you will ever need.</p>
            <div class="hero-buttons">
                <button class="btn-primary" @onclick='() => Nav.NavigateTo("/login")'>Get Started</button>
                <button class="btn-outline">Read The Code</button>
            </div>
        </section>
    </NotAuthorized>
</AuthorizeView>

@code {
    private ElementReference _terminalInput;
    protected override void OnInitialized()
    {
        _vm.StateChanged += StateHasChanged;
    }

    private async Task HandleGlobalKey(KeyboardEventArgs e)
    {
        if (_vm.ShouldFocusTerminal(e) && _terminalInput.Context != null)
        {
            await _terminalInput.FocusAsync();
        }
        else
        {
            Console.WriteLine("Not rendered");
        }
    }

    public void Dispose()
    {
        _vm.StateChanged -= StateHasChanged;
    }
}