@page "/"

@using Nyxon.Client.Services
@inject LayoutService LayoutState

@if (IsLoggedIn)
{
    <div class="dashboard-view">
        <h1 class="dash-greeting">Good afternoon, FinalBoss.</h1>
        
        <div class="dash-search-wrapper">
            <span class="dash-icon">></span>
            <input type="text" class="dash-search" placeholder="Type a command or user...">
        </div>

        <div class="dash-shortcuts">
            <div class="shortcut-chip">N : New Chat</div>
            <div class="shortcut-chip">/ : Search</div>
            <div class="shortcut-chip" style="color: var(--mud-palette-error); border-color: var(--mud-palette-error);" @onclick="ToggleState">
                [DEV: LOGOUT]
            </div>
        </div>
    </div>
}
else
{
    <section class="landing-hero">
        <h1 class="hero-title">Sovereignty over<br>your data.</h1>
        <p class="hero-subtitle">End-to-End Encrypted. Zero Knowledge.<br>The last messenger you will ever need.</p>
        <div class="hero-buttons">
            <button class="btn-primary" @onclick="() => LayoutState.SetLoggedInState(true)">Get Started</button>
            <button class="btn-outline">Read The Code</button>
        </div>
    </section>
}

@code {
    // dev only!!!!
    private bool IsLoggedIn = false;

    private void ToggleState()
    {
        IsLoggedIn = !IsLoggedIn;
    }
}