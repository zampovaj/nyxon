@page "/"
@inject HttpClient Http
@inject IJSRuntime JS

<h3>WebSocket Test</h3>
<input @bind="message" placeholder="Type a message"/>
<button @onclick="SendMessage">Send</button>
<p>Received: @receivedMessage</p>

@code {
    private string message = "";
    private string receivedMessage = "";
    private IJSObjectReference? socket;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var dotnetRef = DotNetObjectReference.Create(this);
            socket = await JS.InvokeAsync<IJSObjectReference>("createWebSocket", "ws://localhost:8080/ws", dotnetRef); // host url
        }
    }

    private async Task SendMessage()
    {
        if (socket != null)
        {
            await JS.InvokeVoidAsync("sendMessage", socket, message);
        }
    }

    [JSInvokable]
    public void ReceiveMessage(string msg)
    {
        receivedMessage = msg;
        StateHasChanged();
    }
}
