@page "/login"
@using Nyxon.Client.Services
@using Nyxon.Core.DTOs
@using Microsoft.AspNetCore.Components.Authorization
@using System.Runtime.CompilerServices
@inject HttpClient Http
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider
@inject IAuthenticationService AuthenticationService
@inject LoginViewModel _vm
@inject ISnackbar Snackbar
@implements IDisposable

<div class="auth-wrapper">
    <div class="@(_vm.IsRegistering ? "auth-card wide" : "auth-card")">
        <div style="text-align: center; @(_vm.IsRegistering ? "margin-bottom: 16px;" : "margin-bottom: 30px;")">
            <h2 class="auth-h1">
                @(_vm.IsRegistering ? "New Identity" : "Welcome Back")
            </h2>
            <p class="auth-p">
                @(_vm.IsRegistering ? "Enter your invite code to join." : "Enter your credentials to decrypt your                vault.")
            </p>
        </div>

        <EditForm Model="@_vm" OnValidSubmit="_vm.SubmitAsync">
            <div class="auth-form">

                <div class="form-content-grid">

                    <div class="form-column">
                        <div>
                            <label class="form-label">USERNAME</label>
                            <InputText @bind-value="_vm.Username" class="input-std" placeholder="Username" />
                        </div>

                        @if (_vm.IsRegistering)
                        {
                            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                                <div>
                                    <label class="form-label">PASSWORD</label>
                                    <InputText @bind-value="_vm.Password" type="password" class="input-std"/>
                                </div>
                                <div>
                                    <label class="form-label">CONFIRM</label>
                                    <InputText @bind-value="_vm.ConfirmPassword" type="password" class="input-std"/>
                                </div>
                            </div>
                            <div>
                                <label class="form-label">INVITE CODE</label>
                                <InputText @bind-value="_vm.InviteCode" class="input-std" placeholder="123ABC456DEF" @oninput="e => _vm.InviteCode = e.Value?.ToString()?.ToUpper()" />
                            </div>
                        }
                        else
                        {
                            <div>
                                <label class="form-label">PASSWORD</label>
                                <InputText @bind-value="_vm.Password" type="password" class="input-std"/>
                            </div>
                        }
                    </div>

                    @if (_vm.IsRegistering)
                    {
                        <div class="form-column passphrase-col">
                            <p class="auth-p" style="font-size: 0.8rem; margin-bottom: 4px;">
                                This passphrase encrypts your private keys and message history.
                                It is never stored or recoverable. Losing it means permanent loss of access to your
                                messages.
                                <span style="color: var(--error);">If lost, it cannot be recovered.</span>
                            </p>

                            <div>
                                <label class="form-label">SECURE PASSPHRASE</label>
                                <InputText @bind-value="_vm.Passphrase" type="text" class="input-std"
                                    placeholder="long phrases beat complex passwords" />
                            </div>
                            <div>
                                <label class="form-label">CONFIRM</label>
                                <InputText @bind-value="_vm.ConfirmPassphrase" type="text" class="input-std"
                                    placeholder="long phrases beat complex passwords" />
                            </div>
                        </div>
                    }
                </div>

                @if (!string.IsNullOrWhiteSpace(_vm.ErrorMessage))
                {
                    <div class="error">
                        @_vm.ErrorMessage
                    </div>
                }

                <button type="submit" class="btn-primary" style="@(_vm.IsRegistering ? "margin-top: 0px;" : "margin-top: 10px;") padding: 10px 0px; width: 100%;"
                    disabled="@_vm.IsBusy">
                    @if (_vm.IsBusy)
                    {
                        <span>Processing...</span>
                    }
                    else
                    {
                        @(_vm.IsRegistering ? "Create Identity" : "Decrypt & Login")
                    }
                </button>
                <p class="auth-link" @onclick="_vm.ToggleMode">
                    @(_vm.IsRegistering ? "I already have an account" : "Create new identity")
                </p>

            </div>
        </EditForm>
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        _vm.StateChanged += StateHasChanged;
    }
    public void Dispose()
    {
        _vm.StateChanged -= StateHasChanged;
    }
}