@page "/settings"
@using Microsoft.AspNetCore.Authorization
@inject NavigationManager Nav
@inject SettingsViewModel _vm
@implements IDisposable

@attribute [Authorize]

<AuthorizeView>
    <Authorized>
        <div class="settings-view">
            <div class="settings-container">
                <h1 class="settings-h1">Settings</h1>

                <div class="settings-grid">
            
                    <div class="settings-column">
                
                        <section class="settings-section">
                            <h2 class="section-title">Profile Information</h2>
                    
                            <div class="settings-row action-row">
                                <div class="settings-info">
                                    <span class="settings-label">USERNAME</span>
                                    <span class="settings-value">@context.User.Identity?.Name</span>
                                </div>
                            </div>

                            <div class="settings-row action-row">
                                <div class="settings-info">
                                    <span class="settings-label">MEMBER SINCE</span>
                                    <span class="settings-value">@_vm.JoinedAt.ToString("MMMM dd, yyyy")</span>
                                </div>
                            </div>
                        </section>

                        <section class="settings-section usage-zone">
                            <h2 class="section-title teal-text">Usage & Others</h2>
                    
                            <div class="settings-row">
                                <div class="settings-info">
                                    <span class="settings-label">INVITES GENERATED</span>
                                    <span class="settings-desc" style="margin-bottom: 8px;">@_vm.InvitesCount out of
                                        @_vm.MaxInvites invites used.</span>
                                    </div>
                                    <div class="progress-bar-container">
                                        <div class="progress-fill" style="width: @(_vm.InvitesPercentage)%"></div>
                                    </div>
                                </div>
                            </section>

                        </div>

                        <div class="settings-column">
                
                            <section class="settings-section security-zone">
                                <h2 class="section-title purple-text">Security</h2>
                    
                                <div class="settings-row action-row">
                                    <div class="settings-info">
                                        <span class="settings-label">PASSWORD</span>
                                        <span class="settings-desc">Update your login credentials.</span>
                                    </div>
                                    <button class="btn-purple" @onclick="() => _showPasswordModal = true">Change
                                        Password</button>
                                    </div>
                                </section>

                                <section class="settings-section danger-zone">
                                    <h2 class="section-title error-text">Danger Zone</h2>
                    
                                    <div class="settings-row action-row">
                                        <div class="settings-info">
                                            <span class="settings-label">DELETE ACCOUNT</span>
                                            <span class="settings-desc">Permanently lose access to your message history.</span>
                                        </div>
                                        <button class="btn-danger" @onclick="() => _showDeleteModal = true">Delete
                                            Account</button>
                                        </div>
                                    </section>

                                </div>
                            </div>
                        </div>
                    </div>
                </Authorized>
            </AuthorizeView>

            @if (_showPasswordModal)
            {
                <div class="modal-overlay" @onclick="() => _showPasswordModal = false">
                    <div class="modal-card" @onclick:stopPropagation="true">
                        <h2 class="auth-h1" style="margin-bottom: 20px;">Change Password</h2>
            
                        <div class="auth-form">
                            <div>
                                <label class="form-label">CURRENT PASSWORD</label>
                                <input type="password" class="input-std" @bind="_vm.Password" placeholder="Enter current password" />
                            </div>
                            <div>
                                <label class="form-label">NEW PASSWORD</label>
                                <input type="password" class="input-std" @bind="_vm.NewPassword" placeholder="Enter new password" />
                            </div>
                            <div>
                                <label class="form-label">CONFIRM NEW PASSWORD</label>
                                <input type="password" class="input-std" @bind="_vm.ConfirmNewPassword"
                                       placeholder="Confirm new password" />
                            </div>

                            <div style="display: flex; gap: 10px; margin-top: 15px;">
                                <button class="btn-outline" style="flex: 1;" @onclick="() => _showPasswordModal = false">Cancel</button>
                                <button class="btn-primary" style="flex: 1;" @onclick="_vm.ChangePasswordAsync">Save Update</button>
                            </div>
                        </div>
                    </div>
                </div>
            }

            @if (_showDeleteModal)
            {
                <div class="modal-overlay" @onclick="() => _showDeleteModal = false">
                    <div class="modal-card" @onclick:stopPropagation="true">
                        <h2 class="auth-h1 error-text" style="margin-bottom: 10px;">Delete Account?</h2>
                        <p class="auth-p" style="margin-bottom: 20px;">
                            This action is irreversible. All your cryptographic keys, conversations, and data will be permanently
                            destroyed.
                        </p>
            
                        <div class="auth-form">
                            <div>
                                <label class="form-label">VERIFY PASSWORD</label>
                                <input type="password" class="input-std error-input" @bind="_vm.Password"
                                       placeholder="Enter password to confirm" />
                            </div>

                            <div style="display: flex; gap: 10px; margin-top: 10px;">
                                <button class="btn-outline" style="flex: 1;" @onclick="() => _showDeleteModal = false">Cancel</button>
                                <button class="btn-danger-solid" style="flex: 1;" @onclick="_vm.DeleteAccountAsync">Delete
                                    Everything</button>
                                </div>
                            </div>
                        </div>
                    </div>
                }

@code {
    private bool _showPasswordModal = false;
    private bool _showDeleteModal = false;

    
    protected override async Task OnInitializedAsync()
    {
        _vm.StateChanged += StateHasChanged;
        await _vm.FetchAccountDataAsync();
    }

    public void Dispose()
    {
        _vm.StateChanged -= StateHasChanged;
    }
}